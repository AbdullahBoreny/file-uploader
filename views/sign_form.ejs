<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up</title>
    <link rel="stylesheet" href="/sign_form.css">
    <link rel="stylesheet" href="/sign_form_card.css">
    <style>

    </style>
</head>

<body>

    <div class="login-container">
        <!-- <h1>LOGIN</h1> -->
        <form method="post" action="/users/sign-up">

            <label for="name">USERNAME</label>
            <input autocomplete="additional-name" onkeyup="saveValue(this)" name="name" type="name" id="name"
                placeholder="name">

            <%- include("./partials/form_errors/nameErrors") %>

                <label for="email">EMAIL</label>
                <input onkeyup="saveValue(this)" name="email" type="email" id="email" placeholder="your@email.com">
                <%- include("./partials/form_errors/emailErrors") %>

                    <label for="password">PASSWORD</label>
                    <input required onkeyup="saveValue(this)" name="password" type="password" id="password">
                    <%- include("./partials/form_errors/passwordErrors") %>

                        <label for="passwordConfirm">CONFIRM PASSWORD</label>
                        <input onkeyup="saveValue(this)" name="passwordConfirm" type="passwordConfirm"
                            id="passwordConfirm">
                        <%- include("./partials/form_errors/passwordConfirmErrors") %>

                            <button type="submit">Sign Up</button>
                            <div class="footer">
                                Already have an account? <a href="/users/log-in">Log In</a>
                            </div>

        </form>
        <div style="display: flex;flex-direction: column;" class="right-sign">
            <%- include("./check.ejs") %>
                <div class="social-login">
                    <div class="social-btn">G</div>
                    <div class="social-btn">F</div>
                    <div class="social-btn">X</div>
                </div>
        </div>
    </div>
    <%- include("scripts/script.ejs") %>

</body>

</html>