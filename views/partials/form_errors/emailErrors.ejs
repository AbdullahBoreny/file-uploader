<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Errors</title>
    <style>
        ul {
            max-width: 700px;
            font-size: 1rem;
            color: red;
        }

        li {
            text-decoration: none;

        }
    </style>
</head>

<body>

    <% if (typeof emailErrors !=="undefined" ) {%>
        <ul>

            <% emailErrors.forEach(function(error) { %>

                <li>
                    <%= error.msg %>

                </li>
                <% }); %>
        </ul>
        <% } %>
</body>

</html>