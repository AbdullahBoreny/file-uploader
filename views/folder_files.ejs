<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Files</title>
</head>

<body>


    <ul>
        <% if (folder && folder.files.length> 0) { %>
            <% folder.files.forEach(function(file) { %>

                <li>
                    Name: <%= file.name %><br>
                        createdAt: <%= file.createdAt.toLocaleString() %><br>
                            <a href="<%= file.link %>">link</a>
                </li>
                <form method="POST" action="/<%= folder.id %>/upload" enctype="multipart/form-data">
                    <input name="avatar" type="file">
                    <br>
                    <input type="submit" value="add">
                </form>
                <% }); %>
                    <% } else { %>
                        <li>No files yet</li>
                        <% } %>
    </ul>


</body>

</html>